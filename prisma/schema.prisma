generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Sex {
  M
  F
  UNKNOWN
}

enum AnimalStatus {
  UNHOSTED
  FOSTERED
  IN_TRIAL
  ADOPTED
  DECEASED
}

model Animal {
  id                Int          @id @default(autoincrement())
  legalId           String?
  name              String
  species           String
  sex               Sex
  color             String?
  findLocation      String?
  status            AnimalStatus @default(UNHOSTED)
  birthDate         DateTime?    @map("birth_date") @db.Date
  isNeutered        Boolean      @map("is_neutered")
  information       String?
  healthInformation String?
  trialDateStart    DateTime?    @db.Date
  familyId          Int?         @map("family_id")
  orgId             Int          @map("organization_id")
  createdAt         DateTime     @default(now()) @map("created_at")
  createdByMemberId Int
  updatedAt         DateTime     @updatedAt
  updatedByMemberId Int?

  family        Family?             @relation(fields: [familyId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  organization  Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  healthActs    AnimalHealthAct[]
  weightEntries AnimalWeightEntry[]
  testEntries   AnimalTestEntry[]
  adoption      AnimalAdoption?

  @@map("animals")
}

enum AnimalHealthActType {
  VACCINATION
  DEWORM
  ANTIFLEA
}

model AnimalHealthAct {
  id        Int                 @id @default(autoincrement())
  animalId  Int
  type      AnimalHealthActType
  date      DateTime            @db.Date
  isFirst   Boolean             @default(false)
  createdAt DateTime            @default(now())

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([animalId, type, date])
}

model AnimalWeightEntry {
  id          Int      @id @default(autoincrement())
  animalId    Int
  date        DateTime @db.Date
  weightGrams Int

  createdAt DateTime @default(now())

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([animalId, date])
}

enum AnimalTestResult {
  POSITIVE
  NEGATIVE
}

model AnimalTestEntry {
  id       Int              @id @default(autoincrement())
  animalId Int
  date     DateTime         @db.Date
  testName String
  result   AnimalTestResult

  createdAt DateTime @default(now())

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([animalId, date])
}

model AnimalAdoption {
  id                       Int       @id @default(autoincrement())
  animalId                 Int       @unique
  adopterFullName          String?
  adopterEmail             String?
  adopterPhoneNumber       String?
  adopterAddress           String?
  adopterZip               String?
  adopterCity              String?
  homeVisitDone            Boolean   @default(false)
  neuteringPlannedAt       DateTime? @db.Date
  adoptionContractSignedAt DateTime? @db.Date
  adoptionFeePaid          Boolean   @default(false)
  legalTransferAt          DateTime? @db.Date
  information              String?
  createdAt                DateTime  @default(now())

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)
}

model Family {
  id                Int      @id @default(autoincrement())
  contactFullName   String   @map("contact_name")
  email             String?
  phoneNumber       String?  @map("phone_number")
  address           String
  zip               String
  city              String
  hasChildren       Boolean  @default(false)
  otherAnimals      String?
  orgId             Int      @map("organization_id")
  createdByMemberId Int
  createdAt         DateTime @default(now())

  animals      Animal[]
  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  members      FamilyMember[]

  @@map("families")
}

model FamilyMember {
  familyId  Int
  memberId  Int
  createdAt DateTime @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([familyId, memberId])
}

enum MemberRole {
  MEMBER
  ADMIN
  SUPERADMIN
}

enum MemberStatus {
  BANNED
  PENDING
  VALIDATED
}

model MemberOrganization {
  memberId Int          @map("member_id")
  orgId    Int          @map("organization_id")
  role     MemberRole
  status   MemberStatus
  joinedAt DateTime     @default(now()) @map("joined_at")

  member       Member       @relation(fields: [memberId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([memberId, orgId])
  @@map("member_organization")
}

model Member {
  id            Int      @id @default(autoincrement())
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  email         String   @unique
  phoneNumber   String   @unique @map("phone_number")
  passwordHash  String   @map("password_hash")
  selectedOrgId Int?
  createdAt     DateTime @default(now()) @map("created_at")

  memberOrganizations MemberOrganization[]
  resetPasswordTokens AuthToken[]
  notifications       Notification[]
  familyMembers       FamilyMember[]

  @@map("members")
}

model Organization {
  id              Int      @id @default(autoincrement())
  name            String
  defaultCurrency String
  description     String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt

  animals               Animal[]
  families              Family[]
  memberOrganizations   MemberOrganization[]
  transactionCategories TransactionCategory[]
  transactions          Transaction[]

  @@map("organizations")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  CHECK
  DIRECT_DEBIT
  OTHER
}

model TransactionCategory {
  id          Int             @id @default(autoincrement())
  orgId       Int
  name        String
  defaultType TransactionType

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, name])
}

model Transaction {
  id            Int             @id @default(autoincrement())
  orgId         Int
  type          TransactionType
  amountInCents Int
  date          DateTime        @db.Date
  categoryId    Int
  counterparty  String?
  paymentMethod PaymentMethod
  note          String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  organization Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  category     TransactionCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
}

enum TokenType {
  RESET_PASSWORD
}

model AuthToken {
  id        Int       @id @default(autoincrement())
  memberId  Int
  tokenHash String
  type      TokenType
  createdAt DateTime  @default(now())
  expiresAt DateTime

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tokenHash])
}

model Notification {
  id            Int       @id @default(autoincrement())
  memberId      Int
  messageKey    String
  messageParams Json?
  href          String?
  sourceKey     String?
  createdAt     DateTime  @default(now())
  readAt        DateTime?
  expiresAt     DateTime?

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, sourceKey])
  @@index([memberId, createdAt])
}

model RateLimit {
  id            Int      @id @default(autoincrement())
  key           String   @unique
  count         Int
  lastAttemptAt DateTime
}
